# ========================================
# Course RAG Pipeline — Environment Config
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM API Keys ---
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# --- Authentication ---
# Admin: full access (upload, admin panel, all query types)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
# Viewer: read-only, general+deadline queries only, 10 messages/session
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=changeme

# --- Google Drive ---
# Path to Google OAuth credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials/oauth_credentials.json
# Path to store the OAuth token after first auth
GOOGLE_TOKEN_PATH=credentials/token.pickle
# Root folder name on Google Drive
DRIVE_ROOT_FOLDER=Course_RAG_Data

# --- ChromaDB ---
CHROMA_PERSIST_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=course_documents

# --- Application ---
# Current active quarter
CURRENT_QUARTER=Spring2026
# Server settings
HOST=0.0.0.0
PORT=8000
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- OCR Settings ---
# For scanned PDFs / image-based slides, Tesseract OCR runs locally.
# Render DPI (higher = clearer text but more memory)
OCR_DPI=200
# Minimum chars per page before OCR is triggered
OCR_FALLBACK_THRESHOLD=30
